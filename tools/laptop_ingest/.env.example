# Anthropic — required for recommend_items.py and draft_item.py
ANTHROPIC_API_KEY=

# Neon — same pooled connection string as Vercel (for sync_catalog + push)
# Get from: Neon dashboard → Connect → Connection string → Pooled
DATABASE_URL=

# Your Amazon Associates store ID (appended to draft Amazon URLs automatically)
AMAZON_ASSOCIATE_TAG=specsideview-20

# Model (defaults to claude-sonnet-4-20250514 if unset)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
