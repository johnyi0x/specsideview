# Anthropic — required for polish_laptop.py
ANTHROPIC_API_KEY=

# Optional: same Neon URL as the Next.js app (for duplicate checks + --push)
DATABASE_URL=

# Optional: Amazon Associates tag appended when you paste a bare /dp/ASIN link
AMAZON_ASSOCIATE_TAG=yourtag-20

# Model (defaults to claude-sonnet-4-20250514 if unset)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
